{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "Logs",
  "uid": "seeker-logs",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "query": "loki", "hide": 0, "current": {} },
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values(container_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Log volume by service",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } } },
      "targets": [ { "refId": "A", "legendFormat": "{{compose_service}}", "expr": "sum by (compose_service) (count_over_time({host=\"hephaestus\", container_name=~\"$container\"} [$__interval]))" } ]
    },
    {
      "type": "timeseries",
      "title": "Error / exception volume",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [ { "refId": "A", "legendFormat": "{{container_name}}", "expr": "sum by (container_name) (count_over_time({host=\"hephaestus\", container_name=~\"$container\"} |~ \"(?i)(error|exception|traceback|fatal|panic)\" [$__interval]))" } ]
    },
    {
      "type": "logs",
      "title": "Logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "refId": "A", "expr": "{host=\"hephaestus\", container_name=~\"$container\"}" } ]
    }
  ]
}
